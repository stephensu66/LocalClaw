PORT=3980
# real is online and mock is dev locally
OPENCLAW_MODE=mock
OPENCLAW_BINARY=openclaw
OPENCLAW_INSTALL_SH=https://openclaw.ai/install.sh
OPENCLAW_INSTALL_PS=https://openclaw.ai/install.ps1
# Example onboarding command (if supported by your OpenClaw version)
# OPENCLAW_ONBOARD_CMD=openclaw onboard --non-interactive
# Example gateway start command
# OPENCLAW_GATEWAY_CMD=openclaw gateway --port 18789 --force
# Example run command template (use {prompt} and {workspace})
# OPENCLAW_RUN_CMD=openclaw agent --local --message "{prompt}" --json
# Optional: additional local skill directory to auto-load
# OPENCLAW_EXTRA_SKILLS_DIR=/absolute/path/to/openclaw-skills

# Web tools configuration (optional but required for live web results)
# OPENCLAW_WEB_SEARCH_ENABLED=true
# OPENCLAW_WEB_SEARCH_PROVIDER=perplexity
# OPENCLAW_WEB_SEARCH_API_KEY=your_api_key
# OPENCLAW_WEB_SEARCH_PERPLEXITY_BASE_URL=https://api.perplexity.ai
# OPENCLAW_WEB_SEARCH_PERPLEXITY_MODEL=perplexity/sonar-pro
# OPENCLAW_WEB_FETCH_ENABLED=true

# Plugins list + install commands (use {provider})
OPENCLAW_PLUGINS_LIST_CMD=openclaw plugins list
OPENCLAW_PLUGIN_INSTALL_CMD=openclaw plugins install {provider}
# Auth command template (optional, mainly for non-openai providers)
# For openai-compatible providers, local-service now writes models.providers config directly.
# If needed, keep this command non-interactive and only use supported CLI flags.
# Example:
# OPENCLAW_AUTH_CMD=printf "{apiKey}\n" | openclaw models auth paste-token --provider {provider}

# If you already have a gateway token in ~/.openclaw/openclaw.json,
# the service will reuse it and skip onboarding.

APP_DATA_DIR=/Users/gaozijian/.openclaw
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
LOG_LEVEL=info
# Optional override
DATABASE_URL='file:/Users/gaozijian/Desktop/AI/openclaw-plugins/prisma/dev.db'
